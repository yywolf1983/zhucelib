<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/keygen_app_name"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#222" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/keygen_subtitle"
            android:textSize="12sp"
            android:textColor="#888" />

        <!-- 私钥选择区 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/kg_section_privkey"
            android:textStyle="bold"
            android:textColor="#1976D2" />

        <TextView
            android:id="@+id/tv_priv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="13sp"
            android:textColor="#666"
            tools:text="未选择私钥文件" />

        <Button
            android:id="@+id/btn_select_priv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/kg_select_priv" />

        <!-- 公钥区 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/kg_section_pubkey"
            android:textStyle="bold"
            android:textColor="#1976D2" />

        <TextView
            android:id="@+id/tv_pub_key"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:padding="10dp"
            android:background="#F5F5F5"
            android:fontFamily="monospace"
            android:textIsSelectable="true"
            android:textSize="10sp"
            android:textColor="#333"
            tools:text="MIIBIjANBgkqhkiG9w0BAQEFAAO..." />

        <Button
            android:id="@+id/btn_copy_pub"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:text="@string/kg_copy_pub" />

        <!-- 生成激活码区 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/kg_section_gen"
            android:textStyle="bold"
            android:textColor="#1976D2" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/kg_request_code_label"
            android:textSize="13sp"
            android:textColor="#555" />

        <EditText
            android:id="@+id/et_request_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="monospace"
            android:hint="@string/kg_request_code_hint"
            android:inputType="textNoSuggestions|textVisiblePassword"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_query_device"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/kg_query_device" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/btn_paste_request"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/kg_paste_request" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_query_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:paddingStart="4dp"
            android:textSize="12sp"
            android:visibility="gone"
            tools:text="已注册 · 3次 · 到期: 2027-07-09"
            tools:visibility="visible" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/kg_valid_days_label"
            android:textSize="13sp"
            android:textColor="#555" />

        <EditText
            android:id="@+id/et_valid_days"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:hint="@string/kg_valid_days_hint"
            android:inputType="number"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_generate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:enabled="false"
            android:text="@string/kg_generate" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/kg_activation_code_label"
            android:textSize="13sp"
            android:textColor="#555" />

        <TextView
            android:id="@+id/tv_activation_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:padding="10dp"
            android:background="#F0F4F8"
            android:fontFamily="monospace"
            android:textIsSelectable="true"
            android:textSize="10sp"
            android:textColor="#1565C0"
            tools:text="ABCDE-FGHIJ-KLMNO-PQRST-..." />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_valid_days_result"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingLeft="10dp"
                android:textSize="12sp"
                android:textColor="#E65100"
                tools:text="购买时长: 365 天" />

            <TextView
                android:id="@+id/tv_expiry_result"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingRight="10dp"
                android:gravity="right"
                android:textSize="12sp"
                android:textColor="#388E3C"
                tools:text="到期: 2025-07-08" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_copy_activation"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:enabled="false"
            android:text="@string/kg_copy_activation" />

        <!-- 注册记录区 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/kg_section_records"
            android:textStyle="bold"
            android:textColor="#1976D2" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_record_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="#666"
                tools:text="共 0 个设备注册记录" />

            <Button
                android:id="@+id/btn_storage_settings"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/kg_storage_settings"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_storage_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:textSize="11sp"
            android:textColor="#AAA"
            tools:text="默认: /storage/emulated/0/..." />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_view_records"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="false"
                android:text="@string/kg_view_records" />

            <View android:layout_width="8dp" android:layout_height="0dp" />

            <Button
                android:id="@+id/btn_export_records"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="false"
                android:text="@string/kg_export_records" />
        </LinearLayout>

        <!-- 设备总览 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="设备总览"
            android:textStyle="bold"
            android:textColor="#1976D2" />

        <TextView
            android:id="@+id/tv_device_overview_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="11sp"
            android:textColor="#AAA"
            android:visibility="gone"
            tools:text="1 个设备 · 3 个包 · 共 5 条记录" />

        <LinearLayout
            android:id="@+id/ll_device_overview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>
