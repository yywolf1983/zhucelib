<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?selectableItemBackground"
    app:cardBackgroundColor="#FAFAFA"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- 第一行: 设备ID -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/item_device_id"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:textColor="#1976D2"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="A1B2C3D4E5F6" />

        </LinearLayout>

        <!-- 包名（有则显示） -->
        <TextView
            android:id="@+id/item_package_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="monospace"
            android:textColor="#7B1FA2"
            android:textSize="11sp"
            android:visibility="gone"
            tools:text="com.example.app"
            tools:visibility="visible" />

        <!-- 第二行: 注册时间 -->
        <TextView
            android:id="@+id/item_reg_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#888"
            android:textSize="12sp"
            tools:text="2026-07-09 22:15:30" />

        <!-- 第三行: 购买时长 + 到期 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/item_valid_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E65100"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="365天" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="到期: "
                android:textColor="#888"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/item_expiry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#388E3C"
                android:textSize="12sp"
                tools:text="2027-07-09" />

        </LinearLayout>

        <!-- 激活码折叠区 -->
        <LinearLayout
            android:id="@+id/item_act_toggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:background="?selectableItemBackground"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/item_act_toggle_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="激活码 ▶"
                android:textColor="#AAA"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/item_activation_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="monospace"
            android:textColor="#1565C0"
            android:textSize="10sp"
            android:ellipsize="end"
            android:maxLines="1"
            android:visibility="gone"
            tools:text="ABCDE-FGHIJ-KLMNO-PQRST-UVWXY" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
