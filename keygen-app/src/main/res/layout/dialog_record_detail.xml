<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/dialog_bg"
    android:orientation="vertical"
    android:paddingTop="16dp">

    <!-- 标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="注册详情"
        android:textColor="#222"
        android:textSize="18sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:background="#E0E0E0" />

    <!-- 可滚动内容区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:fadeScrollbars="false"
        android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
        android:scrollbarStyle="insideOverlay"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 记录ID -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="记录ID: "
                    android:textColor="#888"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/dialog_detail_record_id"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:textColor="#333"
                    android:textSize="13sp"
                    tools:text="1712345678901" />
            </LinearLayout>

            <!-- 设备ID（可点击查历史） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="设备ID: "
                    android:textColor="#888"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/dialog_detail_device_id"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="monospace"
                    android:textColor="#1976D2"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="?selectableItemBackground"
                    tools:text="A1B2C3D4E5F6A1B2C3D4E5F6" />
            </LinearLayout>

            <!-- 包名（有则显示） -->
            <LinearLayout
                android:id="@+id/dialog_detail_pkg_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="包名: "
                    android:textColor="#888"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/dialog_detail_package"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:textColor="#7B1FA2"
                    android:textSize="13sp"
                    tools:text="com.example.app" />
            </LinearLayout>

            <!-- 注册时间 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="注册时间: "
                    android:textColor="#888"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/dialog_detail_reg_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#333"
                    android:textSize="13sp"
                    tools:text="2026-07-09 22:15:30" />
            </LinearLayout>

            <!-- 购买时长 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="购买时长: "
                    android:textColor="#888"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/dialog_detail_valid_days"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#E65100"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="365 天" />
            </LinearLayout>

            <!-- 到期日 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="到期: "
                    android:textColor="#888"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/dialog_detail_expiry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#388E3C"
                    android:textSize="13sp"
                    tools:text="2027-07-09" />
            </LinearLayout>

            <!-- 激活码（折叠） -->
            <LinearLayout
                android:id="@+id/dialog_detail_act_toggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?selectableItemBackground"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="激活码 ▶"
                    android:textColor="#888"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/dialog_detail_activation_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="monospace"
                android:textColor="#1565C0"
                android:textSize="12sp"
                android:textIsSelectable="true"
                android:background="#F0F4F8"
                android:padding="6dp"
                android:visibility="gone"
                tools:text="ABCDE-FGHIJ-KLMNO-PQRST-UVWXY" />

        </LinearLayout>
    </ScrollView>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="4dp"
        android:background="#E0E0E0" />

    <!-- 底部按钮栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="end">

        <Button
            android:id="@+id/dialog_btn_delete_device"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="删除此设备全部"
            android:textColor="#D32F2F"
            android:textSize="13sp" />

        <Button
            android:id="@+id/dialog_btn_delete"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="删除此条"
            android:textColor="#D32F2F"
            android:textSize="13sp" />

        <Button
            android:id="@+id/dialog_btn_close"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="关闭"
            android:textSize="13sp" />

    </LinearLayout>

</LinearLayout>
