<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:src="@android:drawable/ic_lock_lock"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/reggate_tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#222222"
            tools:ignore="HardcodedText"
            tools:text="激活 - 本应用" />

        <TextView
            android:id="@+id/reggate_tv_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textSize="13sp"
            android:textColor="#888888"
            tools:ignore="HardcodedText"
            tools:text="试用剩余 7 天" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/reggate_request_code_label"
            android:textSize="13sp"
            android:textColor="#555555" />

        <TextView
            android:id="@+id/reggate_tv_request_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:padding="12dp"
            android:background="#F0F4F8"
            android:fontFamily="monospace"
            android:textIsSelectable="true"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            tools:ignore="HardcodedText"
            tools:text="ABCD-EFGH-IJKL-MNOP-QRST-UVWX-YZ01-2345" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/reggate_btn_copy_code"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/reggate_copy_request" />

            <Button
                android:id="@+id/reggate_btn_regenerate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/reggate_regenerate" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/reggate_activation_code_label"
            android:textSize="13sp"
            android:textColor="#555555" />

        <EditText
            android:id="@+id/reggate_et_activation_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:minLines="4"
            android:gravity="top|start"
            android:fontFamily="monospace"
            android:hint="@string/reggate_activation_code_hint"
            android:inputType="textMultiLine|textNoSuggestions|textVisiblePassword"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/reggate_btn_paste"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/reggate_paste" />

            <Button
                android:id="@+id/reggate_btn_activate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="false"
                android:text="@string/reggate_activate" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:text="@string/reggate_how_to" />

        <LinearLayout
            android:id="@+id/reggate_contact_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:background="#F8F9FA"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reggate_contact_title"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/reggate_contact_phone_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp"
                android:visibility="gone">
                <TextView
                    android:id="@+id/reggate_tv_contact_phone"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="#555555" />
                <TextView
                    android:id="@+id/reggate_tv_contact_phone_copy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:text="@string/reggate_copy"
                    android:paddingLeft="8dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/reggate_contact_email_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp"
                android:visibility="gone">
                <TextView
                    android:id="@+id/reggate_tv_contact_email"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="#555555" />
                <TextView
                    android:id="@+id/reggate_tv_contact_email_copy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:text="@string/reggate_copy"
                    android:paddingLeft="8dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/reggate_contact_website_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp"
                android:visibility="gone">
                <TextView
                    android:id="@+id/reggate_tv_contact_website"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="#555555" />
                <TextView
                    android:id="@+id/reggate_tv_contact_website_copy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:text="@string/reggate_copy"
                    android:paddingLeft="8dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/reggate_contact_shop_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp"
                android:visibility="gone">
                <TextView
                    android:id="@+id/reggate_tv_contact_shop"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="#555555" />
                <TextView
                    android:id="@+id/reggate_tv_contact_shop_copy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:text="@string/reggate_copy"
                    android:paddingLeft="8dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/reggate_tv_contact_custom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#555555"
                android:layout_marginBottom="6dp"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/reggate_iv_qr_code"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                android:contentDescription="@null" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>